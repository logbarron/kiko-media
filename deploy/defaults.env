# deploy/defaults.env
# Single source of truth for all configurable environment variables.
# Used to generate ConfigDefaults.generated.swift and to drive the orchestrator setup wizard.
# Format: ENV_VAR|type|default|min|max|label|description

# Operational
PUBLIC_PORT|int|3001|1|65535|Public port|Port for public-facing HTTP listener
INTERNAL_PORT|int|3002|1|65535|Internal port|Port for internal/moderation HTTP listener
BIND_ADDRESS|string|127.0.0.1|||Bind address|Bind address for the public HTTP listener (internal listener always binds to 127.0.0.1)
BASE_DIRECTORY|string|~/Documents/kiko-media|||Base directory|Root directory for all runtime data
HEALTH_CHECK_INTERVAL|int|60|1|3600|Health check interval|Seconds between DB watchdog checks (1-3600)
JSON_MAX_BODY_BYTES|int|1048576|65536|4194304|JSON max body bytes|Max JSON request body bytes for API endpoints (64KB-4MB)
WEBHOOK_RETRY_AFTER_SECONDS|int|5|1|120|Webhook Retry-After|Retry-After seconds returned on queue-full webhook 503 (1-120)
EVENT_TIMEZONE|string||||Event timezone|IANA timezone ID (e.g. America/New_York); empty = system timezone
EXTERNAL_SSD_PATH|string||||External SSD path|Archive path for originals (set by setup wizard)
TUSD_MAX_SIZE|int|2147483648|1|10737418240|Max upload size|Maximum upload size in bytes (1B-10GB). Consumed by tusd CLI and index.html, not kiko-media Config

# Processing
MAX_CONCURRENT_IMAGES|int|6|1|64|Max concurrent images|Parallel image processing jobs (1-64)
MAX_CONCURRENT_VIDEOS|int|2|1|16|Max concurrent videos|Parallel video processing jobs (1-16)
VIDEO_SCHEDULER_POLICY|string|auto|||Video scheduler policy|Production video scheduling policy: auto, fifo, none
MAX_CONCURRENT_REBUILD_PROBES|int|8|1|128|Max concurrent rebuild probes|Parallel SSD rebuild candidate/timestamp probe workers (1-128)
MAX_PENDING_WEBHOOK_JOBS|int|1000|0|100000|Max pending webhook jobs|Max queued webhook jobs before returning 503 Retry-After (0-100000)
THUMBNAIL_SIZE|int|512|1|10000|Thumbnail size|Max thumbnail dimension in pixels (1-10000)
THUMBNAIL_QUALITY|double|0.85|0.0|1.0|Thumbnail quality|JPEG quality for thumbnails (0.0-1.0)
PREVIEW_SIZE|int|1440|1|10000|Preview size|Max preview dimension in pixels (1-10000)
PREVIEW_QUALITY|double|0.90|0.0|1.0|Preview quality|JPEG quality for previews (0.0-1.0)
VIDEO_THUMBNAIL_SIZE|int|512|1|10000|Video thumbnail size|Max video thumbnail dimension in pixels (1-10000)
VIDEO_THUMBNAIL_TIME|double|1.0|0.0|300.0|Video thumbnail time|Seconds into video for thumbnail capture (0.0-300.0)
VIDEO_THUMBNAIL_QUALITY|double|0.85|0.0|1.0|Video thumbnail quality|JPEG quality for video thumbnails (0.0-1.0)
VIDEO_TRANSCODE_TIMEOUT|int|300|1|3600|Video transcode timeout|Max seconds for video transcoding (1-3600)
VIDEO_TRANSCODE_PRESET|string|AVAssetExportPreset1920x1080|||Video transcode preset|AVFoundation export preset name

# Thunderbolt offload
TB_WORKERS|string||||Thunderbolt workers|Worker addresses as host:slots,host:slots (empty = disabled)
TB_PORT|int|12400|1|65535|Thunderbolt port|TCP port for worker connections (all workers use same port)
TB_CONNECT_TIMEOUT|int|500|100|30000|Thunderbolt connect timeout|Milliseconds to wait for worker TCP connect (100-30000)

# Frontend (generated index.html)
UPLOAD_CHUNK_SIZE_BYTES|int|5242880|262144|33554432|Upload chunk size|tus-js chunk size in bytes (256KB-32MB)
PARALLEL_UPLOADS|int|1|1|6|Parallel uploads|Concurrent client uploads per browser tab (1-6)
UPLOAD_RETRY_BASE_MS|int|3000|100|60000|Upload retry base|Base delay for upload retry backoff in ms (100-60000)
UPLOAD_RETRY_MAX_MS|int|20000|500|300000|Upload retry max|Max delay for upload retry backoff in ms (500-300000)
UPLOAD_RETRY_STEPS|int|5|2|8|Upload retry steps|Number of retry delay entries (2-8)
POLL_MAX_INFLIGHT|int|3|1|20|Poll max inflight|Max simultaneous pending-tile poll requests (1-20)
GALLERY_POLL_BASE_MS|int|5000|1000|60000|Gallery poll base|Base new-upload gallery poll delay in ms (1000-60000)
GALLERY_POLL_MAX_MS|int|30000|2000|300000|Gallery poll max|Max new-upload gallery poll backoff delay in ms (2000-300000)
PHOTO_THUMB_POLL_BASE_MS|int|500|100|10000|Photo thumb poll base|Base pending photo thumbnail poll delay in ms (100-10000)
PHOTO_THUMB_POLL_MAX_MS|int|5000|500|60000|Photo thumb poll max|Max pending photo thumbnail poll delay in ms (500-60000)
PHOTO_PREVIEW_POLL_BASE_MS|int|1000|100|10000|Photo preview poll base|Base pending photo preview poll delay in ms (100-10000)
PHOTO_PREVIEW_POLL_MAX_MS|int|10000|500|120000|Photo preview poll max|Max pending photo preview poll delay in ms (500-120000)
VIDEO_PREVIEW_EARLY_BASE_MS|int|1000|100|10000|Video poll early base|Base pending video early-phase poll delay in ms (100-10000)
VIDEO_PREVIEW_EARLY_MAX_MS|int|4000|500|60000|Video poll early max|Max pending video early-phase poll delay in ms (500-60000)
VIDEO_PREVIEW_LATE_MS|int|10000|1000|120000|Video poll late delay|Pending video late-phase poll delay in ms (1000-120000)
VIDEO_PREVIEW_EARLY_WINDOW_MS|int|60000|1000|600000|Video early window|Milliseconds before switching video poll to late cadence (1000-600000)

# Security
MAX_IMAGE_PIXELS|int|250000000|1|1000000000|Max image pixels|Maximum total pixels allowed (decompression bomb limit)
MAX_IMAGE_DIMENSION|int|20000|1|100000|Max image dimension|Maximum single dimension in pixels (1-100000)
MAX_COMPRESSION_RATIO|double|200.0|1.0|10000.0|Max compression ratio|Decompression bomb ratio threshold (1.0-10000.0)

# Database
SQLITE_BUSY_TIMEOUT|int|5000|0|60000|SQLite busy timeout|Milliseconds to wait on locked DB (0-60000)
SQLITE_CACHE_SIZE|int|-20000|||SQLite cache size|Cache size in KiB (negative = KiB, positive = pages)
DEFAULT_PAGE_SIZE|int|100|1|10000|Default page size|Default gallery page size (1-10000)
MAX_PAGE_SIZE|int|500|1|100000|Max page size|Maximum gallery page size (1-100000)
MAX_PAGE_OFFSET|int|10000|0|1000000|Max page offset|Maximum gallery offset (0-1000000)
SQL_BATCH_SIZE|int|500|1|999|SQL batch size|Rows per batch for bulk operations (1-999)

# Session
SESSION_COOKIE_TTL|int|14400|1|86400|Session cookie TTL|Cookie lifetime in seconds (1-86400)
SESSION_COOKIE_NAME|string|kiko_session|||Session cookie name|Name of the session cookie
TURNSTILE_VERIFY_TIMEOUT|int|10|1|120|Turnstile verify timeout|Seconds for Turnstile API call (1-120)
TURNSTILE_MAX_RESPONSE|int|65536|1024|1048576|Turnstile max response|Max bytes for Turnstile response (1024-1048576)
TURNSTILE_MAX_INFLIGHT_VERIFICATIONS|int|64|1|1024|Turnstile max in-flight|Maximum concurrent Turnstile siteverify calls (1-1024)
TURNSTILE_OVERLOAD_RETRY_AFTER_SECONDS|int|1|1|10|Turnstile overload Retry-After|Retry-After seconds returned on Turnstile overload/unavailable (1-10)
TURNSTILE_EXPECTED_HOSTNAME|string||||Turnstile expected hostname|Expected hostname returned by siteverify (typically your event domain)
TURNSTILE_EXPECTED_ACTION|string|kiko_verify|||Turnstile expected action|Expected action returned by siteverify (must match frontend widget action)
TURNSTILE_EXPECTED_CDATA|string|kiko_public|||Turnstile expected cdata|Expected cdata returned by siteverify (must match frontend widget cData)

# Caching
CACHE_CONTROL|string|public, max-age=31536000, immutable|||Cache-Control header|Cache-Control value for served media

# Internal
QUEUE_COMPACTION_THRESHOLD|int|100|1|100000|Queue compaction threshold|Completed jobs before queue compaction (1-100000)
SHA256_BUFFER_SIZE|int|1048576|4096|16777216|SHA256 buffer size|Buffer size for file hashing in bytes (4096-16777216)
