func workerUsageInvocation(arguments: [String]) -> String {
    guard let arg0 = arguments.first else {
        return "swift worker.swift"
    }
    let name = URL(fileURLWithPath: arg0).lastPathComponent
    if name.hasSuffix(".swift") {
        return "swift \(name)"
    }
    return name
}

func printWorkerUsage(arguments: [String]) {
    let invocation = workerUsageInvocation(arguments: arguments)
    print("Usage: \(invocation) [--work-dir <path>]")
    print("Options:")
    print("  --work-dir <path>  Override worker temp directory (default: \(defaultWorkDir))")
    print("  -h, --help         Show this help message")
}

func parseWorkerWorkDir(arguments: [String]) -> String {
    let args = Array(arguments.dropFirst())
    if args.isEmpty {
        return defaultWorkDir
    }

    var parsedWorkDir: String?
    var index = 0
    while index < args.count {
        let argument = args[index]
        switch argument {
        case "-h", "--help":
            printWorkerUsage(arguments: arguments)
            exit(0)
        case "--work-dir":
            let valueIndex = index + 1
            guard valueIndex < args.count else {
                print("Missing value for --work-dir")
                printWorkerUsage(arguments: arguments)
                exit(2)
            }
            let raw = args[valueIndex].trimmingCharacters(in: .whitespacesAndNewlines)
            guard !raw.isEmpty else {
                print("Work dir cannot be empty")
                exit(2)
            }
            parsedWorkDir = NSString(string: raw).expandingTildeInPath
            index = valueIndex + 1
        default:
            print("Unknown argument: \(argument)")
            printWorkerUsage(arguments: arguments)
            exit(2)
        }
    }

    return parsedWorkDir ?? defaultWorkDir
}

// Set once during startup (before listener accepts connections), then read-only.
